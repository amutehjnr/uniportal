<%- include('../partials/head', { title: 'University Dashboard – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="flex min-h-[calc(100vh-64px)]">
  <!-- University Sidebar -->
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-white border-r border-gray-100 min-h-screen sticky top-16">
    <div class="p-5 flex flex-col gap-1">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2">University Panel</p>
      <a href="/university/dashboard" class="sidebar-link active">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/></svg>
        Dashboard
      </a>
      <a href="/university/applications" class="sidebar-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Applications
        <span id="pending-badge" class="ml-auto badge badge-red hidden"></span>
      </a>
      <a href="/university/programs" class="sidebar-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        Programs
      </a>
      <a href="/university/scholarships" class="sidebar-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Scholarships
      </a>
      <a href="/university/messages" class="sidebar-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Messages
      </a>
    </div>
  </aside>

  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="mb-8">
      <h1 class="font-display text-2xl font-bold text-dark">University Dashboard</h1>
      <p class="text-gray-500 text-sm mt-1">Manage applications, programs, and student communications</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8" id="stats-grid">
      <% [['stat-total','Total Applications','brand'],['stat-pending','Pending Review','yellow'],['stat-offers','Offers Issued','green'],['stat-programs','Active Programs','purple']].forEach(([id,label,c]) => { %>
      <div class="card">
        <p id="<%= id %>" class="font-display text-2xl font-bold text-dark mb-1">—</p>
        <p class="text-xs text-gray-500"><%= label %></p>
      </div>
      <% }); %>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Recent Applications Table -->
      <div class="card lg:col-span-2 overflow-hidden p-0">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
          <h2 class="font-display font-bold text-dark">Recent Applications</h2>
          <a href="/university/applications" class="text-xs text-brand-600 font-medium">View all →</a>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="apps-table">
            <thead class="bg-gray-50 text-xs text-gray-500">
              <tr>
                <th class="px-5 py-3 text-left font-semibold">Student</th>
                <th class="px-5 py-3 text-left font-semibold">Program</th>
                <th class="px-5 py-3 text-left font-semibold">Status</th>
                <th class="px-5 py-3 text-left font-semibold">Date</th>
                <th class="px-5 py-3 text-left font-semibold"></th>
              </tr>
            </thead>
            <tbody id="apps-tbody">
              <tr><td colspan="5" class="px-5 py-6 text-center text-gray-400">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="space-y-4">
        <div class="card">
          <h3 class="font-display font-bold text-dark mb-4">Quick Actions</h3>
          <div class="space-y-2">
            <a href="/university/applications?status=submitted" class="flex items-center gap-3 p-3 rounded-xl hover:bg-brand-50 transition-colors">
              <div class="w-8 h-8 bg-brand-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <span class="text-sm font-medium text-gray-700">Review Pending</span>
            </a>
            <button onclick="document.getElementById('add-program-modal').classList.remove('hidden')" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-green-50 transition-colors">
              <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              </div>
              <span class="text-sm font-medium text-gray-700">Add Program</span>
            </button>
            <a href="/university/scholarships" class="flex items-center gap-3 p-3 rounded-xl hover:bg-purple-50 transition-colors">
              <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <span class="text-sm font-medium text-gray-700">Manage Scholarships</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Add Program Modal -->
<div id="add-program-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg animate-slide-up max-h-[90vh] overflow-y-auto">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between sticky top-0 bg-white">
      <h3 class="font-display text-xl font-bold text-dark">Add New Program</h3>
      <button onclick="document.getElementById('add-program-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
    </div>
    <form id="add-program-form" class="p-6 space-y-4">
      <div><label class="block text-sm font-medium text-dark mb-1.5">Program Name *</label><input name="name" required placeholder="e.g. Master of Computer Science" class="input-field" /></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-dark mb-1.5">Degree *</label>
          <select name="degree" required class="input-field">
            <option value="Bachelor">Bachelor</option><option value="Master">Master</option><option value="MBA">MBA</option><option value="PhD">PhD</option><option value="Certificate">Certificate</option>
          </select>
        </div>
        <div><label class="block text-sm font-medium text-dark mb-1.5">Field *</label><input name="field" required placeholder="Computer Science" class="input-field" /></div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-medium text-dark mb-1.5">Tuition (USD/year) *</label><input type="number" name="tuitionAmount" required min="0" placeholder="25000" class="input-field" /></div>
        <div><label class="block text-sm font-medium text-dark mb-1.5">Duration (years)</label><input type="number" name="durationValue" min="1" max="8" placeholder="2" class="input-field" /></div>
      </div>
      <div><label class="block text-sm font-medium text-dark mb-1.5">Description</label><textarea name="description" rows="3" class="input-field resize-none" placeholder="Program overview…"></textarea></div>
      <div class="flex gap-3 pt-2">
        <button type="button" onclick="document.getElementById('add-program-modal').classList.add('hidden')" class="btn-secondary flex-1 justify-center">Cancel</button>
        <button type="submit" class="btn-primary flex-1 justify-center">Create Program</button>
      </div>
    </form>
  </div>
</div>

<script>
const STATUS_COLORS = { draft:'badge-gray', submitted:'badge-blue', under_review:'badge-yellow', offer_extended:'badge-purple', accepted:'badge-green', rejected:'badge-red' };

async function loadDashboard() {
  try {
    const data = await apiCall('/api/v1/universities/dashboard/stats');
    const { stats, recentApplications } = data.data;

    document.getElementById('stat-total').textContent = stats.applications || 0;
    document.getElementById('stat-pending').textContent = stats.pendingReview || 0;
    document.getElementById('stat-offers').textContent = '—';
    document.getElementById('stat-programs').textContent = stats.totalPrograms || 0;

    if (stats.pendingReview > 0) {
      const badge = document.getElementById('pending-badge');
      badge.textContent = stats.pendingReview;
      badge.classList.remove('hidden');
    }

    document.getElementById('apps-tbody').innerHTML = recentApplications.length
      ? recentApplications.map(a => `
        <tr class="border-b border-gray-50 hover:bg-gray-50/50">
          <td class="px-5 py-3">
            <div>
              <p class="font-medium text-dark text-xs">${a.student?.firstName||''} ${a.student?.lastName||''}</p>
              <p class="text-xs text-gray-400">${a.student?.email||''}</p>
            </div>
          </td>
          <td class="px-5 py-3 text-xs text-gray-600">${a.program?.name||'—'}</td>
          <td class="px-5 py-3"><span class="${STATUS_COLORS[a.status]||'badge-gray'} text-xs">${a.status?.replace(/_/g,' ')}</span></td>
          <td class="px-5 py-3 text-xs text-gray-400">${new Date(a.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric'})}</td>
          <td class="px-5 py-3"><a href="/university/applications/${a._id}" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Review →</a></td>
        </tr>`).join('')
      : '<tr><td colspan="5" class="px-5 py-8 text-center text-gray-400 text-sm">No applications yet</td></tr>';
  } catch (err) { showToast(err.message, 'error'); }
}

document.getElementById('add-program-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  try {
    await apiCall('/api/v1/universities/programs', {
      method: 'POST',
      body: JSON.stringify({
        name: form.name.value, degree: form.degree.value, field: form.field.value,
        description: form.description.value,
        tuitionFee: { amount: parseFloat(form.tuitionAmount.value), currency: 'USD', per: 'year' },
        duration: { value: parseInt(form.durationValue.value||2), unit: 'years' },
      }),
    });
    showToast('Program created successfully!', 'success');
    document.getElementById('add-program-modal').classList.add('hidden');
    form.reset();
    loadDashboard();
  } catch (err) { showToast(err.message, 'error'); }
});

loadDashboard();
</script>
<%- include('../partials/footer') %>
