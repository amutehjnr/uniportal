<%- include('../partials/head', { title: 'Programs – University Portal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-white border-r border-gray-100 min-h-screen sticky top-16 p-5 gap-1">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2">University Panel</p>
    <a href="/university/dashboard" class="sidebar-link">Dashboard</a>
    <a href="/university/applications" class="sidebar-link">Applications</a>
    <a href="/university/programs" class="sidebar-link active">Programs</a>
    <a href="/university/scholarships" class="sidebar-link">Scholarships</a>
    <a href="/university/messages" class="sidebar-link">Messages</a>
  </aside>
  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-display text-2xl font-bold text-dark">Programs</h1>
      <button onclick="document.getElementById('add-modal').classList.remove('hidden')" class="btn-primary">+ Add Program</button>
    </div>
    <div id="programs-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
  </main>
</div>

<div id="add-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg animate-slide-up max-h-[90vh] overflow-y-auto p-6">
    <div class="flex items-center justify-between mb-4"><h3 class="font-display text-xl font-bold text-dark">Add Program</h3><button onclick="document.getElementById('add-modal').classList.add('hidden')" class="text-gray-400">✕</button></div>
    <form id="program-form" class="space-y-4">
      <div><label class="block text-sm font-medium text-dark mb-1.5">Program Name *</label><input name="name" required placeholder="e.g. Master of Science in CS" class="input-field"/></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm font-medium text-dark mb-1.5">Degree *</label><select name="degree" required class="input-field"><option>Bachelor</option><option>Master</option><option>MBA</option><option>PhD</option><option>Certificate</option></select></div>
        <div><label class="block text-sm font-medium text-dark mb-1.5">Field *</label><input name="field" required placeholder="Computer Science" class="input-field"/></div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm font-medium text-dark mb-1.5">Tuition (USD/yr) *</label><input type="number" name="tuition" required min="0" class="input-field"/></div>
        <div><label class="block text-sm font-medium text-dark mb-1.5">Duration (years)</label><input type="number" name="duration" min="1" max="8" value="2" class="input-field"/></div>
      </div>
      <div><label class="block text-sm font-medium text-dark mb-1.5">Mode</label><select name="mode" class="input-field"><option value="on-campus">On Campus</option><option value="online">Online</option><option value="hybrid">Hybrid</option></select></div>
      <div><label class="block text-sm font-medium text-dark mb-1.5">Description</label><textarea name="description" rows="3" class="input-field resize-none"></textarea></div>
      <div class="flex gap-3 pt-2"><button type="button" onclick="document.getElementById('add-modal').classList.add('hidden')" class="btn-secondary flex-1 justify-center">Cancel</button><button type="submit" class="btn-primary flex-1 justify-center">Create Program</button></div>
    </form>
  </div>
</div>

<script>
async function loadPrograms() {
  try {
    const meData = await apiCall('/api/v1/auth/me');
    const uniId = meData.data.universityRef;
    if (!uniId) { document.getElementById('programs-grid').innerHTML='<div class="col-span-full card text-center py-8 text-gray-400">No university profile linked</div>'; return; }
    const data = await apiCall(`/api/v1/universities/${uniId}/programs`);
    const grid = document.getElementById('programs-grid');
    if (!data.data.length) { grid.innerHTML='<div class="col-span-full card text-center py-8 text-gray-400">No programs yet. Click "Add Program" to get started.</div>'; return; }
    grid.innerHTML = data.data.map(p=>`
      <div class="card hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-2"><span class="badge badge-blue text-xs">${p.degree}</span><span class="badge badge-gray text-xs capitalize">${p.mode||'on-campus'}</span></div>
        <h3 class="font-semibold text-dark mb-1">${p.name}</h3>
        <p class="text-xs text-gray-500 mb-3">${p.field} · ${p.duration?.value||2} yr${p.duration?.value>1?'s':''}</p>
        <p class="text-sm font-bold text-brand-600">USD ${(p.tuitionFee?.amount||0).toLocaleString()}<span class="text-xs font-normal text-gray-400">/${p.tuitionFee?.per||'year'}</span></p>
        <div class="mt-3 pt-3 border-t border-gray-100"><span class="${p.isActive?'badge-green':'badge-red'} badge text-xs">${p.isActive?'Active':'Inactive'}</span></div>
      </div>`).join('');
  } catch(err){showToast(err.message,'error');}
}

document.getElementById('program-form').addEventListener('submit', async(e)=>{
  e.preventDefault(); const f=e.target;
  try {
    await apiCall('/api/v1/universities/programs', { method:'POST', body:JSON.stringify({ name:f.name.value, degree:f.degree.value, field:f.field.value, mode:f.mode.value, description:f.description.value, tuitionFee:{amount:parseFloat(f.tuition.value),currency:'USD',per:'year'}, duration:{value:parseInt(f.duration.value),unit:'years'}, intakes:['Fall','Spring'] }) });
    showToast('Program created!','success'); document.getElementById('add-modal').classList.add('hidden'); f.reset(); loadPrograms();
  } catch(err){showToast(err.message,'error');}
});
loadPrograms();
</script>
<%- include('../partials/footer') %>
