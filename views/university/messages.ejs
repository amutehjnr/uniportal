<%- include('../partials/head', { title: 'Messages – University Portal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-white border-r border-gray-100 min-h-screen sticky top-16 p-5 gap-1">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2">University Panel</p>
    <a href="/university/dashboard" class="sidebar-link">Dashboard</a>
    <a href="/university/applications" class="sidebar-link">Applications</a>
    <a href="/university/programs" class="sidebar-link">Programs</a>
    <a href="/university/scholarships" class="sidebar-link">Scholarships</a>
    <a href="/university/messages" class="sidebar-link active">Messages</a>
  </aside>
  <main class="flex-1 flex overflow-hidden" style="height:calc(100vh - 64px)">
    <div class="w-80 shrink-0 border-r border-gray-100 bg-white flex flex-col">
      <div class="p-4 border-b border-gray-100"><h2 class="font-display font-bold text-dark">Messages</h2></div>
      <div id="convos-list" class="flex-1 overflow-y-auto divide-y divide-gray-50"><div class="p-4 text-sm text-gray-400 text-center">Loading…</div></div>
    </div>
    <div class="flex-1 flex flex-col bg-surface">
      <div id="empty-state" class="flex-1 flex items-center justify-center">
        <div class="text-center"><div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-4"><svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></div><p class="font-medium text-dark">Select a conversation</p></div>
      </div>
      <div id="active-chat" class="hidden flex-1 flex flex-col">
        <div id="chat-header" class="px-5 py-4 bg-white border-b border-gray-100 flex items-center gap-3">
          <div id="chat-avatar" class="w-9 h-9 rounded-xl bg-brand-100 flex items-center justify-center font-bold text-brand-600"></div>
          <div><p id="chat-name" class="font-semibold text-dark text-sm"></p><p id="chat-subject" class="text-xs text-gray-400"></p></div>
        </div>
        <div id="messages-container" class="flex-1 overflow-y-auto p-5 space-y-4"></div>
        <div class="p-4 bg-white border-t border-gray-100">
          <div class="flex items-end gap-3">
            <textarea id="message-input" rows="1" placeholder="Type a message…" class="input-field resize-none flex-1" style="min-height:44px;max-height:120px" onkeydown="handleMsgKey(event)" oninput="autoResize(this)"></textarea>
            <button onclick="sendMessage()" class="btn-primary px-4 py-2.5 shrink-0"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg></button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<script>
let activeConvoId=null;
const ME_ID='<%= user._id %>';

async function loadConversations() {
  try {
    const data=await apiCall('/api/v1/messages/conversations');
    const list=document.getElementById('convos-list');
    if (!data.data.length){list.innerHTML='<div class="p-4 text-sm text-gray-400 text-center">No conversations</div>';return;}
    list.innerHTML=data.data.map(c=>{
      const other=c.participants?.find(p=>String(p._id)!==ME_ID)||c.participants?.[0];
      return `<button onclick="openConversation('${c._id}','${other?.firstName||''} ${other?.lastName||''}','${c.subject||''}')" class="w-full text-left px-4 py-3.5 hover:bg-brand-50 transition-colors flex items-center gap-3">
        <div class="w-9 h-9 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center font-bold text-sm shrink-0">${(other?.firstName||'?').charAt(0).toUpperCase()}</div>
        <div class="min-w-0 flex-1"><p class="text-sm font-medium text-dark truncate">${other?other.firstName+' '+other.lastName:'Unknown'}</p><p class="text-xs text-gray-400 truncate">${c.lastMessage?.content||c.subject||'No messages'}</p></div>
      </button>`;
    }).join('');
  } catch(err){showToast(err.message,'error');}
}

async function openConversation(id,name,subject) {
  activeConvoId=id;
  document.getElementById('empty-state').classList.add('hidden');
  document.getElementById('active-chat').classList.remove('hidden');
  document.getElementById('chat-name').textContent=name;
  document.getElementById('chat-subject').textContent=subject||'Direct Message';
  document.getElementById('chat-avatar').textContent=name.charAt(0).toUpperCase();
  try {
    const data=await apiCall(`/api/v1/messages/conversations/${id}/messages`);
    const c=document.getElementById('messages-container');
    c.innerHTML=data.data.length?data.data.map(m=>{
      const isMine=String(m.sender?._id)===ME_ID||String(m.sender)===ME_ID;
      return `<div class="flex ${isMine?'justify-end':'justify-start'} gap-2">
        <div class="max-w-[70%]"><div class="px-4 py-2.5 rounded-2xl text-sm ${isMine?'bg-brand-600 text-white':'bg-white border border-gray-100 text-dark shadow-sm'}">${m.content}</div>
        <p class="text-xs text-gray-400 mt-1 ${isMine?'text-right':'text-left'}">${new Date(m.createdAt).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}</p></div></div>`;
    }).join(''):'<div class="text-center text-sm text-gray-400 py-8">No messages yet</div>';
    c.scrollTop=c.scrollHeight;
  } catch(err){showToast(err.message,'error');}
}

async function sendMessage() {
  const input=document.getElementById('message-input');
  const content=input.value.trim();
  if (!content||!activeConvoId) return;
  input.value=''; input.style.height='auto';
  try {
    const data=await apiCall(`/api/v1/messages/conversations/${activeConvoId}/messages`,{method:'POST',body:JSON.stringify({content})});
    const c=document.getElementById('messages-container');
    c.insertAdjacentHTML('beforeend',`<div class="flex justify-end"><div class="max-w-[70%]"><div class="px-4 py-2.5 rounded-2xl text-sm bg-brand-600 text-white">${content}</div></div></div>`);
    c.scrollTop=c.scrollHeight;
  } catch(err){showToast(err.message,'error');}
}
function handleMsgKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
loadConversations();
</script>
<%- include('../partials/footer') %>
