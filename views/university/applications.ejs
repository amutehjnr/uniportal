<%- include('../partials/head', { title: 'Applications – University Portal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-white border-r border-gray-100 min-h-screen sticky top-16 p-5 gap-1">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2">University Panel</p>
    <a href="/university/dashboard" class="sidebar-link">Dashboard</a>
    <a href="/university/applications" class="sidebar-link active">Applications</a>
    <a href="/university/programs" class="sidebar-link">Programs</a>
    <a href="/university/scholarships" class="sidebar-link">Scholarships</a>
    <a href="/university/messages" class="sidebar-link">Messages</a>
  </aside>
  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-display text-2xl font-bold text-dark">Applications</h1>
    </div>
    <div class="card mb-5 flex gap-3 flex-wrap">
      <select id="status-filter" class="input-field w-auto" onchange="loadApplications()">
        <option value="">All Statuses</option>
        <option value="submitted">Submitted</option><option value="under_review">Under Review</option>
        <option value="documents_requested">Docs Requested</option><option value="interview_scheduled">Interview Scheduled</option>
        <option value="offer_extended">Offer Extended</option><option value="accepted">Accepted</option><option value="rejected">Rejected</option>
      </select>
    </div>
    <div class="card overflow-hidden p-0">
      <table class="w-full text-sm"><thead class="bg-gray-50 border-b border-gray-100 text-xs text-gray-500">
        <tr><th class="px-5 py-3 text-left font-semibold">Student</th><th class="px-5 py-3 text-left font-semibold">Program</th><th class="px-5 py-3 text-left font-semibold">Intake</th><th class="px-5 py-3 text-left font-semibold">Status</th><th class="px-5 py-3 text-left font-semibold">Date</th><th class="px-5 py-3"></th></tr>
      </thead><tbody id="apps-tbody"><tr><td colspan="6" class="px-5 py-8 text-center text-gray-400">Loading…</td></tr></tbody></table>
    </div>
    <div id="pagination" class="flex justify-center mt-5 gap-2"></div>
  </main>
</div>
<script>
const STATUS_COLORS={draft:'badge-gray',submitted:'badge-blue',under_review:'badge-yellow',documents_requested:'badge-yellow',interview_scheduled:'badge-blue',offer_extended:'badge-purple',accepted:'badge-green',rejected:'badge-red',withdrawn:'badge-gray'};
let currentPage=1;
async function loadApplications(page=currentPage) {
  currentPage=page;
  const status=document.getElementById('status-filter').value;
  const params=new URLSearchParams({page,limit:20,...(status&&{status})});
  try {
    const data=await apiCall(`/api/v1/applications?${params}`);
    const tbody=document.getElementById('apps-tbody');
    tbody.innerHTML=data.data.length?data.data.map(a=>`
      <tr class="border-b border-gray-50 hover:bg-gray-50/50">
        <td class="px-5 py-3"><p class="font-medium text-dark text-sm">${a.student?.firstName||''} ${a.student?.lastName||''}</p><p class="text-xs text-gray-400">${a.student?.email||''}</p></td>
        <td class="px-5 py-3 text-sm text-gray-600">${a.program?.name||'—'}</td>
        <td class="px-5 py-3 text-sm text-gray-600">${a.intake} ${a.intakeYear}</td>
        <td class="px-5 py-3"><span class="${STATUS_COLORS[a.status]||'badge-gray'} text-xs">${(a.status||'').replace(/_/g,' ')}</span></td>
        <td class="px-5 py-3 text-xs text-gray-400">${new Date(a.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</td>
        <td class="px-5 py-3"><a href="/university/applications/${a._id}" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Review →</a></td>
      </tr>`).join(''):'<tr><td colspan="6" class="px-5 py-8 text-center text-gray-400">No applications found</td></tr>';
    const{pages,page:pg}=data.pagination;
    if(pages>1) document.getElementById('pagination').innerHTML=Array.from({length:pages},(_,i)=>i+1).map(p=>`<button onclick="loadApplications(${p})" class="${p===pg?'btn-primary':'btn-secondary'} text-xs py-1.5 px-3">${p}</button>`).join('');
  } catch(err){showToast(err.message,'error');}
}
loadApplications();
</script>
<%- include('../partials/footer') %>
