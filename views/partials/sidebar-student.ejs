<aside class="w-64 shrink-0 hidden lg:flex flex-col bg-white border-r border-gray-100 min-h-screen sticky top-16">
  <div class="p-5 flex flex-col gap-1">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2">Main</p>
    <a href="/dashboard" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/></svg>
      Dashboard
    </a>
    <a href="/student/profile" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      My Profile
    </a>

    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2 mt-4">Applications</p>
    <a href="/student/applications" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'applications' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      My Applications
    </a>
    <a href="/student/offers" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'offers' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      Offer Letters
    </a>
    <a href="/student/payments" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'payments' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
      Payments
    </a>

    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2 mt-4">Discover</p>
    <a href="/universities" class="sidebar-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      Browse Universities
    </a>
    <a href="/scholarships" class="sidebar-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Scholarships
    </a>

    <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest px-4 mb-2 mt-4">Communication</p>
    <a href="/student/messages" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'messages' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      Messages
    </a>
    <a href="/student/notifications" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'notifications' ? 'active' : '' %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      Notifications
      <span id="notif-count" class="ml-auto text-xs bg-red-500 text-white rounded-full px-1.5 py-0.5 font-bold hidden"></span>
    </a>
  </div>

  <!-- Profile card at bottom -->
  <div class="mt-auto p-5 border-t border-gray-100">
    <div class="flex items-center gap-3">
      <% if (user && user.avatar) { %>
        <img src="<%= user.avatar %>" class="w-9 h-9 rounded-xl object-cover" />
      <% } else { %>
        <div class="w-9 h-9 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center font-display font-bold text-sm">
          <%= user ? user.firstName.charAt(0).toUpperCase() : 'U' %>
        </div>
      <% } %>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-dark truncate"><%= user ? user.firstName + ' ' + user.lastName : '' %></p>
        <p class="text-xs text-gray-400 truncate"><%= user ? user.email : '' %></p>
      </div>
    </div>
  </div>
</aside>
