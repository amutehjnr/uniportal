<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
        </div>
        <span class="font-display font-bold text-xl text-dark">Uni<span class="text-brand-600">Portal</span></span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6">
        <a href="/universities" class="text-sm font-medium text-gray-600 hover:text-brand-600 transition-colors">Universities</a>
        <a href="/programs" class="text-sm font-medium text-gray-600 hover:text-brand-600 transition-colors">Programs</a>
        <a href="/scholarships" class="text-sm font-medium text-gray-600 hover:text-brand-600 transition-colors">Scholarships</a>
      </div>

      <!-- Auth Area -->
      <div class="flex items-center gap-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <!-- Notifications Bell -->
          <button id="notif-btn" class="relative p-2 text-gray-500 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-colors" title="Notifications">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            <span id="notif-badge" class="hidden absolute -top-0.5 -right-0.5 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center font-bold"></span>
          </button>

          <!-- User Menu -->
          <div class="relative" x-data="{ open: false }">
            <button onclick="toggleUserMenu()" class="flex items-center gap-2 p-1.5 rounded-xl hover:bg-gray-50 transition-colors">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="Avatar" class="w-8 h-8 rounded-lg object-cover" />
              <% } else { %>
                <div class="w-8 h-8 bg-brand-100 text-brand-700 rounded-lg flex items-center justify-center font-display font-bold text-sm">
                  <%= user.firstName.charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <div class="hidden md:block text-left">
                <p class="text-sm font-medium text-dark leading-none"><%= user.firstName %></p>
                <p class="text-xs text-gray-500 capitalize leading-none mt-0.5"><%= user.role.replace('_',' ') %></p>
              </div>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div id="user-menu" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-2xl shadow-xl border border-gray-100 py-2 z-50">
              <div class="px-4 py-2.5 border-b border-gray-100">
                <p class="font-medium text-sm text-dark"><%= user.firstName %> <%= user.lastName %></p>
                <p class="text-xs text-gray-500"><%= user.email %></p>
              </div>
              <% if (user.role === 'student') { %>
                <a href="/dashboard" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/></svg>
                  Dashboard
                </a>
                <a href="/student/profile" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  My Profile
                </a>
              <% } else if (user.role === 'university' || user.role === 'admission_officer') { %>
                <a href="/university/dashboard" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Dashboard</a>
              <% } else if (user.role === 'admin' || user.role === 'super_admin') { %>
                <a href="/admin/dashboard" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Admin Panel</a>
              <% } %>
              <div class="border-t border-gray-100 mt-1 pt-1">
                <button onclick="logout()" class="w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                  Sign Out
                </button>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="btn-secondary">Sign In</a>
          <a href="/register" class="btn-primary">Get Started</a>
        <% } %>

        <!-- Mobile menu button -->
        <button onclick="toggleMobileMenu()" class="md:hidden p-2 text-gray-500 hover:text-brand-600 rounded-xl">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 pt-3">
      <a href="/universities" class="block py-2 px-2 text-sm text-gray-700 hover:text-brand-600">Universities</a>
      <a href="/programs" class="block py-2 px-2 text-sm text-gray-700 hover:text-brand-600">Programs</a>
      <a href="/scholarships" class="block py-2 px-2 text-sm text-gray-700 hover:text-brand-600">Scholarships</a>
    </div>
  </div>
</nav>
