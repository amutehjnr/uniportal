<%- include('../partials/head', { title: 'Sign In – UniPortal' }) %>

<div class="min-h-screen grid lg:grid-cols-2">
  <!-- Left: Form -->
  <div class="flex flex-col justify-center px-8 py-12 sm:px-16 lg:px-20 xl:px-28">
    <div class="w-full max-w-md mx-auto animate-slide-up">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 mb-10">
        <div class="w-9 h-9 bg-brand-600 rounded-xl flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
        </div>
        <span class="font-display font-bold text-xl text-dark">Uni<span class="text-brand-600">Portal</span></span>
      </a>

      <h1 class="font-display text-3xl font-bold text-dark mb-2">Welcome back</h1>
      <p class="text-gray-500 mb-8">Sign in to your UniPortal account</p>

      <form id="login-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-dark mb-1.5">Email Address</label>
          <input name="email" type="email" required placeholder="you@email.com" class="input-field" />
        </div>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-sm font-medium text-dark">Password</label>
            <a href="/forgot-password" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Forgot password?</a>
          </div>
          <div class="relative">
            <input name="password" type="password" id="password-input" required placeholder="••••••••" class="input-field pr-11" />
            <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </button>
          </div>
        </div>

        <button type="submit" id="login-btn" class="btn-primary w-full justify-center py-3 text-base">
          Sign In
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-6">
        Don't have an account? <a href="/register" class="text-brand-600 font-semibold hover:text-brand-700">Create one free</a>
      </p>

      <div class="mt-8 p-4 bg-brand-50 rounded-xl text-xs text-brand-700">
        <p class="font-semibold mb-1">Demo Credentials:</p>
        <p>Student: student@demo.com / Demo1234</p>
        <p>Admin: admin@demo.com / Demo1234</p>
      </div>
    </div>
  </div>

  <!-- Right: Hero -->
  <div class="hidden lg:block relative overflow-hidden bg-brand-900">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-dark"></div>
    <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 20% 80%, #60a5fa 0%, transparent 50%), radial-gradient(circle at 80% 20%, #818cf8 0%, transparent 50%)"></div>
    <div class="relative z-10 flex flex-col justify-center h-full px-16 text-white">
      <div class="max-w-md">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 rounded-full text-xs font-medium mb-8 backdrop-blur">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          Trusted by 50,000+ students worldwide
        </div>
        <h2 class="font-display text-4xl font-bold leading-tight mb-6">Your gateway to US universities</h2>
        <p class="text-brand-200 text-lg leading-relaxed mb-10">Apply to top-ranked US universities, discover scholarships, and track every step of your admission journey — all in one platform.</p>

        <div class="space-y-4">
          <% const features = ['500+ verified US universities', '$2B+ scholarships listed', 'Real-time application tracking', 'Direct messaging with officers']; %>
          <% features.forEach(f => { %>
          <div class="flex items-center gap-3">
            <div class="w-5 h-5 bg-green-400/20 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-brand-100 text-sm"><%= f %></span>
          </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function togglePassword() {
  const input = document.getElementById('password-input');
  input.type = input.type === 'password' ? 'text' : 'password';
}

document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('login-btn');
  btn.disabled = true;
  btn.innerHTML = '<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Signing in…';
  try {
    const form = e.target;
    const data = await apiCall('/api/v1/auth/login', {
      method: 'POST',
      body: JSON.stringify({ email: form.email.value, password: form.password.value }),
    });
    const role = data.data.user.role;
    const redirectMap = { student: '/dashboard', university: '/university/dashboard', admission_officer: '/university/dashboard', admin: '/admin/dashboard', super_admin: '/admin/dashboard' };
    showToast('Welcome back! Redirecting…', 'success');
    setTimeout(() => window.location.href = redirectMap[role] || '/dashboard', 800);
  } catch (err) {
    showToast(err.message, 'error');
    btn.disabled = false;
    btn.innerHTML = 'Sign In';
  }
});
</script>
<%- include('../partials/footer') %>
