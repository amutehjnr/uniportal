<%- include('../partials/head', { title: 'Reset Password – UniPortal' }) %>
<div class="min-h-screen flex items-center justify-center px-4 bg-surface">
  <div class="w-full max-w-md animate-slide-up">
    <div class="card">
      <a href="/" class="flex items-center gap-2.5 mb-8">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/></svg></div>
        <span class="font-display font-bold text-xl text-dark">Uni<span class="text-brand-600">Portal</span></span>
      </a>
      <h1 class="font-display text-2xl font-bold text-dark mb-2">Set new password</h1>
      <p class="text-gray-500 text-sm mb-6">Choose a strong password of at least 8 characters.</p>
      <form id="reset-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-dark mb-1.5">New Password</label>
          <input name="password" type="password" id="pw" required minlength="8" placeholder="Min. 8 chars, upper+lower+number" class="input-field" />
        </div>
        <div>
          <label class="block text-sm font-medium text-dark mb-1.5">Confirm Password</label>
          <input name="confirm" type="password" required placeholder="Repeat password" class="input-field" />
        </div>
        <button type="submit" id="submit-btn" class="btn-primary w-full justify-center py-3">Reset Password</button>
      </form>
    </div>
  </div>
</div>
<script>
const token = window.location.pathname.split('/').pop();
document.getElementById('reset-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const { password, confirm } = e.target;
  if (password.value !== confirm.value) { showToast('Passwords do not match.', 'error'); return; }
  const btn = document.getElementById('submit-btn');
  btn.disabled = true; btn.textContent = 'Resetting…';
  try {
    await apiCall(`/api/v1/auth/reset-password/${token}`, { method: 'PATCH', body: JSON.stringify({ password: password.value }) });
    showToast('Password reset! Redirecting to login…', 'success');
    setTimeout(() => window.location.href = '/login', 1500);
  } catch (err) { showToast(err.message, 'error'); btn.disabled = false; btn.textContent = 'Reset Password'; }
});
</script>
<%- include('../partials/footer') %>
