<%- include('../partials/head', { title: 'Scholarships – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="bg-brand-900 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display text-4xl font-bold text-white mb-3">Scholarships for International Students</h1>
    <p class="text-brand-200 text-lg">Discover billions in funding opportunities at US universities</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Filters Sidebar -->
    <aside class="w-full lg:w-64 shrink-0">
      <div class="card sticky top-24">
        <h3 class="font-display font-bold text-dark mb-4">Filter Scholarships</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Type</label>
            <select id="filter-type" class="input-field text-sm" onchange="loadScholarships()">
              <option value="">All Types</option>
              <option value="merit">Merit</option>
              <option value="need">Need-Based</option>
              <option value="full_ride">Full Ride</option>
              <option value="full_tuition">Full Tuition</option>
              <option value="partial">Partial</option>
              <option value="research">Research</option>
              <option value="diversity">Diversity</option>
              <option value="government">Government</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Degree Level</label>
            <select id="filter-degree" class="input-field text-sm" onchange="loadScholarships()">
              <option value="">All Levels</option>
              <option value="Bachelor">Bachelor</option>
              <option value="Master">Master</option>
              <option value="PhD">PhD</option>
              <option value="MBA">MBA</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Nationality</label>
            <input id="filter-nationality" type="text" placeholder="e.g. Nigeria, Ghana" class="input-field text-sm" oninput="debounce(loadScholarships, 500)()" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Search</label>
            <input id="filter-search" type="text" placeholder="Scholarship name…" class="input-field text-sm" oninput="debounce(loadScholarships, 500)()" />
          </div>
          <button onclick="clearFilters()" class="btn-secondary w-full justify-center text-sm">Clear Filters</button>
        </div>
      </div>
    </aside>

    <!-- Results -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-5">
        <p id="results-count" class="text-sm text-gray-500">Loading…</p>
        <select id="sort-by" class="input-field w-auto text-sm" onchange="loadScholarships()">
          <option value="deadline">Deadline Soon</option>
          <option value="-createdAt">Newest First</option>
          <option value="isFeatured">Featured</option>
        </select>
      </div>
      <div id="scholarships-grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5"></div>
      <div id="pagination" class="flex justify-center mt-8 gap-2"></div>
    </div>
  </div>
</div>

<script>
let currentPage = 1;
let debounceTimer;

function debounce(fn, delay) {
  return function(...args) {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => fn.apply(this, args), delay);
  };
}

function clearFilters() {
  document.getElementById('filter-type').value = '';
  document.getElementById('filter-degree').value = '';
  document.getElementById('filter-nationality').value = '';
  document.getElementById('filter-search').value = '';
  loadScholarships(1);
}

async function loadScholarships(page = currentPage) {
  currentPage = page;
  const params = new URLSearchParams({
    page, limit: 9,
    ...(document.getElementById('filter-type').value && { type: document.getElementById('filter-type').value }),
    ...(document.getElementById('filter-degree').value && { degree: document.getElementById('filter-degree').value }),
    ...(document.getElementById('filter-nationality').value && { nationality: document.getElementById('filter-nationality').value }),
    ...(document.getElementById('filter-search').value && { search: document.getElementById('filter-search').value }),
  });

  const grid = document.getElementById('scholarships-grid');
  grid.innerHTML = Array(6).fill('<div class="card animate-pulse h-48 bg-gray-50"></div>').join('');

  try {
    const data = await apiCall(`/api/v1/scholarships?${params}`);
    document.getElementById('results-count').textContent = `${data.pagination.total} scholarship${data.pagination.total !== 1 ? 's' : ''} found`;

    if (!data.data.length) {
      grid.innerHTML = '<div class="col-span-full text-center py-16"><p class="text-gray-400">No scholarships match your filters</p><button onclick="clearFilters()" class="btn-secondary mt-4">Clear Filters</button></div>'; return;
    }

    grid.innerHTML = data.data.map(s => {
      const daysLeft = Math.ceil((new Date(s.deadline) - new Date()) / (1000*60*60*24));
      const urgency = daysLeft <= 14 ? 'text-red-600' : daysLeft <= 30 ? 'text-orange-600' : 'text-gray-400';
      return `
      <a href="/scholarships/${s._id}" class="card hover:shadow-lg transition-all group border hover:border-brand-200">
        ${s.isFeatured ? '<div class="absolute -top-px left-4 w-16 h-0.5 bg-gradient-to-r from-brand-500 to-purple-500 rounded-b"></div>' : ''}
        <div class="flex items-start justify-between mb-3">
          <span class="badge badge-green capitalize text-xs">${(s.type||'').replace(/_/g,' ')}</span>
          <span class="${urgency} text-xs font-medium">${daysLeft > 0 ? daysLeft + 'd left' : 'Closed'}</span>
        </div>
        <h3 class="font-display font-bold text-dark text-sm mb-1 group-hover:text-brand-600 transition-colors">${s.name}</h3>
        <p class="text-xs text-gray-500 mb-3">${s.university?.name || 'Open Scholarship'}</p>
        <p class="text-lg font-bold text-green-600 mb-3">
          ${s.amount?.isPercentage ? s.amount.percentage + '% Tuition' : s.amount?.value ? 'USD ' + s.amount.value.toLocaleString() : 'Full Scholarship'}
        </p>
        <div class="flex flex-wrap gap-1 mb-4">
          ${(s.eligibility?.degreeLevel||[]).slice(0,3).map(d => `<span class="badge badge-blue text-xs">${d}</span>`).join('')}
          ${(s.eligibility?.nationalities||[]).length ? `<span class="badge badge-gray text-xs">${s.eligibility.nationalities.length} countries</span>` : ''}
        </div>
        <div class="pt-3 border-t border-gray-100 flex items-center justify-between">
          <span class="text-xs text-gray-400">Deadline: ${new Date(s.deadline).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>
          <span class="text-xs text-brand-600 font-medium group-hover:text-brand-700">Apply Now →</span>
        </div>
      </a>`;
    }).join('');

    // Pagination
    const { pages, page: pg } = data.pagination;
    if (pages > 1) {
      document.getElementById('pagination').innerHTML = Array.from({length:pages},(_,i)=>i+1).map(p =>
        `<button onclick="loadScholarships(${p})" class="${p===pg?'btn-primary':'btn-secondary'} text-xs py-1.5 px-3">${p}</button>`
      ).join('');
    } else { document.getElementById('pagination').innerHTML = ''; }
  } catch (err) {
    grid.innerHTML = `<div class="col-span-full text-center py-8 text-red-500">${err.message}</div>`;
  }
}

loadScholarships(1);
</script>
<%- include('../partials/footer') %>
