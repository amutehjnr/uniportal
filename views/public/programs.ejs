<%- include('../partials/head', { title: 'Programs – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="bg-gradient-to-br from-brand-900 to-dark py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-bold text-white mb-3">Browse Programs</h1>
    <p class="text-brand-200 text-lg mb-8">Explore thousands of degree programs across 500+ US universities</p>
    <div class="max-w-xl flex gap-3">
      <input id="hero-search" type="text" placeholder="Search programs, fields, universities…" class="input-field bg-white/10 border-white/20 text-white placeholder-white/50 flex-1" oninput="debounce(loadPrograms,500)()" />
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col lg:flex-row gap-8">
    <aside class="w-full lg:w-64 shrink-0">
      <div class="card sticky top-24">
        <h3 class="font-display font-bold text-dark mb-4">Filter Programs</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Degree</label>
            <select id="filter-degree" class="input-field text-sm" onchange="loadPrograms()">
              <option value="">All Degrees</option>
              <option value="Bachelor">Bachelor</option><option value="Master">Master</option>
              <option value="MBA">MBA</option><option value="PhD">PhD</option><option value="Certificate">Certificate</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Mode</label>
            <select id="filter-mode" class="input-field text-sm" onchange="loadPrograms()">
              <option value="">All Modes</option>
              <option value="on-campus">On Campus</option><option value="online">Online</option><option value="hybrid">Hybrid</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Intake</label>
            <select id="filter-intake" class="input-field text-sm" onchange="loadPrograms()">
              <option value="">Any Intake</option>
              <option value="Fall">Fall</option><option value="Spring">Spring</option><option value="Summer">Summer</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Max Tuition (USD/yr)</label>
            <input type="number" id="filter-maxfee" placeholder="100000" class="input-field text-sm" oninput="debounce(loadPrograms,600)()" />
          </div>
          <button onclick="clearFilters()" class="btn-secondary w-full justify-center text-sm">Clear All</button>
        </div>
      </div>
    </aside>

    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-5">
        <p id="results-count" class="text-sm text-gray-500">Loading…</p>
        <select id="sort-by" class="input-field w-auto text-sm" onchange="loadPrograms()">
          <option value="-createdAt">Newest</option>
          <option value="tuitionFee.amount">Lowest Tuition</option>
          <option value="-tuitionFee.amount">Highest Tuition</option>
        </select>
      </div>
      <div id="programs-grid" class="grid sm:grid-cols-2 gap-4"></div>
      <div id="pagination" class="flex justify-center mt-8 gap-2"></div>
    </div>
  </div>
</div>

<script>
let currentPage = 1;
let debounceTimer;
function debounce(fn, delay) { return function() { clearTimeout(debounceTimer); debounceTimer = setTimeout(fn, delay); }; }
function clearFilters() { ['filter-degree','filter-mode','filter-intake','filter-maxfee'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; }); document.getElementById('hero-search').value=''; loadPrograms(1); }

// Pre-fill from URL params
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('degree')) document.addEventListener('DOMContentLoaded', () => { const el = document.getElementById('filter-degree'); if(el) el.value = urlParams.get('degree'); });
if (urlParams.get('field')) document.addEventListener('DOMContentLoaded', () => { const el = document.getElementById('hero-search'); if(el) el.value = urlParams.get('field'); });

async function loadPrograms(page = currentPage) {
  currentPage = page;
  const params = new URLSearchParams({
    page, limit: 12,
    sort: document.getElementById('sort-by').value,
    ...(document.getElementById('filter-degree').value && { degree: document.getElementById('filter-degree').value }),
    ...(document.getElementById('filter-intake').value && { intake: document.getElementById('filter-intake').value }),
    ...(document.getElementById('filter-maxfee').value && { maxFee: document.getElementById('filter-maxfee').value }),
    ...(document.getElementById('hero-search').value && { search: document.getElementById('hero-search').value }),
  });

  const grid = document.getElementById('programs-grid');
  grid.innerHTML = Array(6).fill('<div class="card animate-pulse h-48 bg-gray-50"></div>').join('');

  try {
    const data = await apiCall(`/api/v1/programs?${params}`);
    document.getElementById('results-count').textContent = `${data.pagination.total} program${data.pagination.total!==1?'s':''} found`;

    if (!data.data.length) { grid.innerHTML='<div class="col-span-full card text-center py-12 text-gray-400">No programs found. Try adjusting your filters.</div>'; return; }

    grid.innerHTML = data.data.map(p => `
      <div class="card hover:shadow-lg transition-all group border hover:border-brand-200">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="badge badge-blue text-xs">${p.degree}</span>
            <span class="badge badge-gray text-xs capitalize">${p.mode||'on-campus'}</span>
          </div>
          ${p.featured ? '<span class="badge badge-purple text-xs">Featured</span>' : ''}
        </div>
        <h3 class="font-display font-bold text-dark mb-1 group-hover:text-brand-600 transition-colors">${p.name}</h3>
        <p class="text-xs text-gray-500 mb-1">${p.field}</p>
        <div class="flex items-center gap-2 mb-3">
          ${p.university?.logo ? `<img src="${p.university.logo}" class="w-5 h-5 rounded object-cover"/>` : ''}
          <p class="text-xs text-gray-500 font-medium">${p.university?.name||'—'}</p>
        </div>
        <p class="text-xs text-gray-400 mb-4">📍 ${p.university?.location?.city||'—'}, ${p.university?.location?.state||'—'} · ${p.duration?.value||'—'} yr${(p.duration?.value||1)>1?'s':''}</p>
        <div class="flex items-center justify-between pt-3 border-t border-gray-100">
          <div>
            <p class="font-bold text-brand-600">USD ${(p.tuitionFee?.amount||0).toLocaleString()}</p>
            <p class="text-xs text-gray-400">per ${p.tuitionFee?.per||'year'}</p>
          </div>
          <a href="/universities/${p.university?.slug||p.university?._id}" class="btn-primary text-xs py-1.5 px-3">Apply Now →</a>
        </div>
      </div>`).join('');

    const { pages, page: pg } = data.pagination;
    if (pages > 1) {
      document.getElementById('pagination').innerHTML = Array.from({length:pages},(_,i)=>i+1).map(p =>
        `<button onclick="loadPrograms(${p})" class="${p===pg?'btn-primary':'btn-secondary'} text-xs py-1.5 px-3">${p}</button>`
      ).join('');
    }
  } catch (err) { grid.innerHTML = `<div class="col-span-full card text-center py-8 text-red-500">${err.message}</div>`; }
}

loadPrograms(1);
</script>
<%- include('../partials/footer') %>
