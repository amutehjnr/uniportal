<%- include('../partials/head', { title: 'Scholarship – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <a href="/scholarships" class="flex items-center gap-2 text-sm text-gray-500 hover:text-brand-600 mb-6">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Scholarships
  </a>
  <div id="scholarship-content"><div class="card animate-pulse h-64"></div></div>
</div>

<script>
const scholarshipId = window.location.pathname.split('/').pop();

async function loadScholarship() {
  try {
    const data = await apiCall(`/api/v1/scholarships/${scholarshipId}`);
    const s = data.data;
    document.title = s.name + ' – UniPortal';
    const daysLeft = Math.ceil((new Date(s.deadline) - new Date()) / (1000*60*60*24));
    const isExpired = daysLeft <= 0;

    document.getElementById('scholarship-content').innerHTML = `
    <div class="grid lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-5">
        <div class="card">
          <div class="flex items-start gap-5 mb-5">
            <div class="w-16 h-16 rounded-2xl overflow-hidden bg-green-100 shrink-0 flex items-center justify-center">
              ${s.university?.logo ? `<img src="${s.university.logo}" class="w-full h-full object-cover"/>` : '<span class="text-2xl">🎓</span>'}
            </div>
            <div>
              <div class="flex items-center gap-2 flex-wrap mb-2">
                <span class="badge badge-green capitalize">${(s.type||'').replace(/_/g,' ')}</span>
                ${s.isFeatured ? '<span class="badge badge-purple">Featured</span>' : ''}
                <span class="${isExpired?'badge-red':daysLeft<=14?'badge-yellow':'badge-green'} badge">${isExpired?'Closed':daysLeft+'d left'}</span>
              </div>
              <h1 class="font-display text-2xl font-bold text-dark">${s.name}</h1>
              <p class="text-gray-500 mt-1">${s.university?.name || 'Open Scholarship'}</p>
            </div>
          </div>

          <!-- Award amount -->
          <div class="bg-green-50 rounded-2xl p-5 mb-5 text-center">
            <p class="text-xs text-green-600 font-semibold uppercase tracking-wide mb-1">Award Amount</p>
            <p class="font-display text-3xl font-bold text-green-700">
              ${s.amount?.isPercentage ? s.amount.percentage + '% Tuition Covered' : s.amount?.value ? 'USD ' + s.amount.value.toLocaleString() : 'Full Scholarship'}
            </p>
            ${s.amount?.covers?.length ? `<p class="text-sm text-green-600 mt-1">Covers: ${s.amount.covers.join(', ')}</p>` : ''}
          </div>

          <h3 class="font-display font-bold text-dark mb-3">About This Scholarship</h3>
          <p class="text-gray-600 leading-relaxed">${s.description}</p>
        </div>

        <!-- Requirements -->
        ${s.applicationRequirements?.length ? `
        <div class="card">
          <h3 class="font-display font-bold text-dark mb-4">Application Requirements</h3>
          <ul class="space-y-2">
            ${s.applicationRequirements.map(r => `<li class="flex items-start gap-2 text-sm text-gray-600"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 mt-1.5 shrink-0"></span>${r}</li>`).join('')}
          </ul>
        </div>` : ''}
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">
        <div class="card">
          <h3 class="font-display font-bold text-dark mb-4">Key Dates</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Application Deadline</span>
              <span class="font-semibold text-dark text-sm ${isExpired?'text-red-600':''}">${new Date(s.deadline).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>
            </div>
            ${s.startDate ? `<div class="flex items-center justify-between"><span class="text-sm text-gray-600">Start Date</span><span class="font-semibold text-dark text-sm">${new Date(s.startDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span></div>` : ''}
            ${s.duration?.semesters ? `<div class="flex items-center justify-between"><span class="text-sm text-gray-600">Duration</span><span class="font-semibold text-dark text-sm">${s.duration.semesters} semesters</span></div>` : ''}
            ${s.duration?.renewable ? '<div class="flex items-center gap-2 mt-2"><span class="badge badge-green text-xs">Renewable</span><span class="text-xs text-gray-500">${s.duration.renewalCriteria||""}</span></div>' : ''}
          </div>
        </div>

        <div class="card">
          <h3 class="font-display font-bold text-dark mb-4">Eligibility</h3>
          <div class="space-y-2 text-sm text-gray-600">
            ${s.eligibility?.gpaMinimum ? `<div class="flex justify-between"><span>Min GPA</span><span class="font-semibold text-dark">${s.eligibility.gpaMinimum}+</span></div>` : ''}
            ${s.eligibility?.degreeLevel?.length ? `<div><p class="text-gray-400 text-xs mb-1">Degree Levels</p><div class="flex flex-wrap gap-1">${s.eligibility.degreeLevel.map(d=>`<span class="badge badge-blue text-xs">${d}</span>`).join('')}</div></div>` : ''}
            ${s.eligibility?.nationalities?.length && !s.eligibility.nationalities.includes('All') ? `<div><p class="text-gray-400 text-xs mb-1">Eligible Nationalities</p><p class="text-xs">${s.eligibility.nationalities.slice(0,5).join(', ')}${s.eligibility.nationalities.length>5?' +more':''}</p></div>` : '<div class="badge badge-green text-xs">Open to All Nationalities</div>'}
          </div>
        </div>

        ${!isExpired ? `
        <div class="card bg-brand-600 text-white">
          <h3 class="font-display font-bold text-lg mb-2">Apply for this Scholarship</h3>
          <p class="text-brand-200 text-sm mb-4">Create your profile and apply through UniPortal for free.</p>
          ${s.applicationUrl ? `<a href="${s.applicationUrl}" target="_blank" class="block w-full text-center bg-white text-brand-700 font-semibold py-2.5 rounded-xl hover:bg-brand-50 text-sm mb-2">External Application →</a>` : ''}
          <a href="/register" class="block w-full text-center bg-brand-500 text-white font-semibold py-2.5 rounded-xl hover:bg-brand-400 text-sm border border-brand-400">Apply via UniPortal</a>
        </div>` : '<div class="card text-center py-4"><span class="badge badge-red text-sm px-4 py-2">Application Closed</span></div>'}
      </div>
    </div>`;
  } catch (err) {
    document.getElementById('scholarship-content').innerHTML = `<div class="card text-center py-8 text-red-500">${err.message}</div>`;
  }
}

loadScholarship();
</script>
<%- include('../partials/footer') %>
