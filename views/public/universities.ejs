<%- include('../partials/head', { title: 'Universities – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="bg-gradient-to-br from-brand-900 to-dark py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="font-display text-4xl font-bold text-white mb-3">Explore US Universities</h1>
    <p class="text-brand-200 text-lg mb-8">500+ verified universities accepting international applications</p>
    <div class="max-w-xl flex gap-3">
      <input id="hero-search" type="text" placeholder="Search by name, city, or field…" class="input-field bg-white/10 border-white/20 text-white placeholder-white/50 flex-1" oninput="debounce(loadUniversities,500)()" />
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar Filters -->
    <aside class="w-full lg:w-64 shrink-0">
      <div class="card sticky top-24">
        <h3 class="font-display font-bold text-dark mb-4">Filters</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">State</label>
            <select id="filter-state" class="input-field text-sm" onchange="loadUniversities()">
              <option value="">All States</option>
              <% ['California','New York','Texas','Massachusetts','Florida','Illinois','Pennsylvania','Ohio','Michigan','Washington','Georgia','North Carolina','Virginia','Arizona','Colorado'].forEach(s => { %>
              <option value="<%= s %>"><%= s %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Type</label>
            <select id="filter-type" class="input-field text-sm" onchange="loadUniversities()">
              <option value="">All Types</option>
              <option value="public">Public</option>
              <option value="private">Private</option>
              <option value="community">Community</option>
            </select>
          </div>
          <button onclick="clearFilters()" class="btn-secondary w-full justify-center text-sm">Clear</button>
        </div>
      </div>
    </aside>

    <!-- Results -->
    <div class="flex-1">
      <div class="flex items-center justify-between mb-5">
        <p id="results-count" class="text-sm text-gray-500">Loading…</p>
        <select id="sort-by" class="input-field w-auto text-sm" onchange="loadUniversities()">
          <option value="-createdAt">Newest</option>
          <option value="name">A–Z</option>
        </select>
      </div>
      <div id="unis-grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5"></div>
      <div id="pagination" class="flex justify-center mt-8 gap-2"></div>
    </div>
  </div>
</div>

<script>
let currentPage = 1;
let debounceTimer;
function debounce(fn, delay) { return function(...args) { clearTimeout(debounceTimer); debounceTimer = setTimeout(() => fn.apply(this, args), delay); }; }
function clearFilters() { document.getElementById('filter-state').value=''; document.getElementById('filter-type').value=''; document.getElementById('hero-search').value=''; loadUniversities(1); }

async function loadUniversities(page = currentPage) {
  currentPage = page;
  const params = new URLSearchParams({
    page, limit: 12,
    sort: document.getElementById('sort-by').value,
    ...(document.getElementById('filter-state').value && { state: document.getElementById('filter-state').value }),
    ...(document.getElementById('filter-type').value && { type: document.getElementById('filter-type').value }),
    ...(document.getElementById('hero-search').value && { search: document.getElementById('hero-search').value }),
  });
  const grid = document.getElementById('unis-grid');
  grid.innerHTML = Array(6).fill('<div class="rounded-2xl border border-gray-100 animate-pulse overflow-hidden"><div class="h-36 bg-gray-100"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-100 rounded w-3/4"></div><div class="h-3 bg-gray-100 rounded w-1/2"></div></div></div>').join('');

  try {
    const data = await apiCall(`/api/v1/universities?${params}`);
    document.getElementById('results-count').textContent = `${data.pagination.total} universit${data.pagination.total!==1?'ies':'y'} found`;
    if (!data.data.length) { grid.innerHTML = '<div class="col-span-full text-center py-16 text-gray-400">No universities found</div>'; return; }

    grid.innerHTML = data.data.map(u => `
      <a href="/universities/${u.slug}" class="group rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all hover:border-brand-200 bg-white">
        <div class="h-36 bg-gradient-to-br from-brand-100 to-brand-50 relative overflow-hidden flex items-center justify-center">
          ${u.coverImage?`<img src="${u.coverImage}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>`:`<span class="font-display text-5xl font-bold text-brand-200">${u.name.charAt(0)}</span>`}
          ${u.featured?'<span class="absolute top-2 left-2 badge badge-blue text-xs">Featured</span>':''}
        </div>
        <div class="p-4">
          <div class="flex items-start gap-3 mb-2">
            ${u.logo?`<img src="${u.logo}" class="w-9 h-9 rounded-xl object-cover border border-gray-100 shrink-0"/>`:`<div class="w-9 h-9 bg-brand-100 rounded-xl flex items-center justify-center shrink-0 font-bold text-brand-600 text-sm">${u.name.charAt(0)}</div>`}
            <div class="min-w-0">
              <h3 class="font-display font-bold text-dark text-sm leading-tight group-hover:text-brand-600 transition-colors">${u.name}</h3>
              <p class="text-xs text-gray-500 mt-0.5">${u.location?.city}, ${u.location?.state} · <span class="capitalize">${u.type||''}</span></p>
            </div>
          </div>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
            <div class="flex gap-2 flex-wrap">
              ${u.ranking?.usnews?`<span class="badge badge-purple text-xs">#${u.ranking.usnews} US News</span>`:''}
              ${u.stats?.acceptanceRate?`<span class="badge badge-gray text-xs">${u.stats.acceptanceRate}% admit</span>`:''}
            </div>
            <span class="text-xs text-brand-600 font-medium">View →</span>
          </div>
        </div>
      </a>`).join('');

    const { pages, page: pg } = data.pagination;
    if (pages > 1) {
      document.getElementById('pagination').innerHTML = Array.from({length:pages},(_,i)=>i+1).map(p =>
        `<button onclick="loadUniversities(${p})" class="${p===pg?'btn-primary':'btn-secondary'} text-xs py-1.5 px-3">${p}</button>`
      ).join('');
    }
  } catch (err) { grid.innerHTML = `<div class="col-span-full text-center py-8 text-red-500">${err.message}</div>`; }
}

document.addEventListener('DOMContentLoaded', () => loadUniversities(1));
</script>
<%- include('../partials/footer') %>
