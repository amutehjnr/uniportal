<%- include('../partials/head', { title: 'Scholarships – UniPortal Admin' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-dark min-h-screen sticky top-16 p-5 gap-1">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest px-4 mb-2 mt-2">Admin Panel</p>
    <a href="/admin/dashboard" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">Dashboard</a>
    <a href="/admin/users" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">Users</a>
    <a href="/admin/universities" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">Universities</a>
    <a href="/admin/payments" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">Payments</a>
    <a href="/admin/scholarships" class="sidebar-link active text-white">Scholarships</a>
    <a href="/admin/audit-logs" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">Audit Logs</a>
  </aside>
  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-display text-2xl font-bold text-dark">Scholarships</h1>
      <a href="/scholarships" target="_blank" class="btn-secondary text-sm">View Public Listing →</a>
    </div>
    <div id="scholarships-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
  </main>
</div>
<script>
async function loadScholarships() {
  try {
    const data = await apiCall('/api/v1/scholarships?limit=50');
    const grid = document.getElementById('scholarships-grid');
    if (!data.data.length) { grid.innerHTML='<div class="col-span-full card text-center py-8 text-gray-400">No scholarships yet</div>'; return; }
    grid.innerHTML = data.data.map(s => `
      <div class="card hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-2">
          <span class="badge badge-green capitalize text-xs">${(s.type||'').replace(/_/g,' ')}</span>
          ${s.isFeatured?'<span class="badge badge-purple text-xs">Featured</span>':''}
        </div>
        <h3 class="font-semibold text-dark text-sm mb-1">${s.name}</h3>
        <p class="text-xs text-gray-500 mb-2">${s.university?.name||'Platform Scholarship'}</p>
        <p class="text-sm font-bold text-green-600">${s.amount?.isPercentage?s.amount.percentage+'% tuition':s.amount?.value?'USD '+s.amount.value.toLocaleString():'Full Scholarship'}</p>
        <p class="text-xs text-gray-400 mt-2">Deadline: ${new Date(s.deadline).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</p>
        <div class="mt-3 pt-3 border-t border-gray-100">
          <span class="${s.isActive&&new Date(s.deadline)>=new Date()?'badge-green':'badge-red'} badge text-xs">${s.isActive&&new Date(s.deadline)>=new Date()?'Active':'Closed'}</span>
        </div>
      </div>`).join('');
  } catch (err) { showToast(err.message,'error'); }
}
loadScholarships();
</script>
<%- include('../partials/footer') %>
