<%- include('../partials/head', { title: 'Admin Dashboard – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>

<div class="flex min-h-[calc(100vh-64px)]">
  <!-- Admin Sidebar -->
  <aside class="w-64 shrink-0 hidden lg:flex flex-col bg-dark min-h-screen sticky top-16">
    <div class="p-5 flex flex-col gap-1">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest px-4 mb-2 mt-2">Admin Panel</p>
      <a href="/admin/dashboard" class="sidebar-link active text-white">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/></svg>
        Dashboard
      </a>
      <a href="/admin/users" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        Users
      </a>
      <a href="/admin/universities" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Universities
      </a>
      <a href="/admin/payments" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
        Payments
        <span id="pending-payments-badge" class="ml-auto text-xs bg-red-500 text-white rounded-full px-1.5 py-0.5 font-bold hidden"></span>
      </a>
      <a href="/admin/scholarships" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Scholarships
      </a>
      <a href="/admin/audit-logs" class="sidebar-link text-gray-400 hover:text-white hover:bg-white/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Audit Logs
      </a>
    </div>
  </aside>

  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="mb-8">
      <h1 class="font-display text-2xl font-bold text-dark">Admin Dashboard</h1>
      <p class="text-gray-500 text-sm mt-1">Platform overview and management</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
      <% const cards = [
        { id:'stat-users', label:'Total Users', color:'blue', icon:'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z' },
        { id:'stat-universities', label:'Universities', color:'purple', icon:'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
        { id:'stat-applications', label:'Applications', color:'green', icon:'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
        { id:'stat-payments', label:'Pending Payments', color:'orange', icon:'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z' },
        { id:'stat-verifications', label:'Pending Verifications', color:'red', icon:'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
      ]; %>
      <% cards.forEach(c => { %>
      <div class="card group hover:shadow-md transition-shadow cursor-default">
        <div class="w-9 h-9 bg-<%= c.color === 'blue' ? 'brand' : c.color %>-100 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-<%= c.color === 'blue' ? 'brand' : c.color %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= c.icon %>"/></svg>
        </div>
        <p id="<%= c.id %>" class="font-display text-2xl font-bold text-dark">—</p>
        <p class="text-xs text-gray-500 mt-1"><%= c.label %></p>
      </div>
      <% }); %>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Applications by Status Chart -->
      <div class="card lg:col-span-1">
        <h2 class="font-display font-bold text-dark mb-4">Applications by Status</h2>
        <div id="status-chart" class="space-y-3"></div>
      </div>

      <!-- Recent Audit Activity -->
      <div class="card lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-display font-bold text-dark">Recent Activity</h2>
          <a href="/admin/audit-logs" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View all →</a>
        </div>
        <div id="activity-feed" class="space-y-2">
          <div class="animate-pulse space-y-2"><% for(let i=0;i<5;i++) { %><div class="h-10 bg-gray-100 rounded-xl"></div><% } %></div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
const STATUS_COLORS_MAP = { draft:'bg-gray-400', submitted:'bg-brand-500', under_review:'bg-yellow-500', offer_extended:'bg-purple-500', accepted:'bg-green-500', rejected:'bg-red-500', enrolled:'bg-teal-500' };

async function loadAdminDashboard() {
  try {
    const data = await apiCall('/api/v1/admin/dashboard');
    const stats = data.data;

    document.getElementById('stat-users').textContent = (stats.totalUsers||0).toLocaleString();
    document.getElementById('stat-universities').textContent = (stats.totalUniversities||0).toLocaleString();
    document.getElementById('stat-applications').textContent = (stats.totalApplications||0).toLocaleString();
    document.getElementById('stat-payments').textContent = (stats.pendingPayments||0);
    document.getElementById('stat-verifications').textContent = (stats.pendingVerifications||0);

    if (stats.pendingPayments > 0) {
      const badge = document.getElementById('pending-payments-badge');
      badge.textContent = stats.pendingPayments;
      badge.classList.remove('hidden');
    }

    // Status chart
    const total = stats.appsByStatus?.reduce((s,c) => s + c.count, 0) || 1;
    document.getElementById('status-chart').innerHTML = (stats.appsByStatus||[]).map(s => `
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-600 capitalize">${(s._id||'').replace(/_/g,' ')}</span>
          <span class="font-medium text-dark">${s.count}</span>
        </div>
        <div class="h-2 bg-gray-100 rounded-full">
          <div class="h-2 ${STATUS_COLORS_MAP[s._id]||'bg-gray-400'} rounded-full transition-all" style="width:${Math.round(s.count/total*100)}%"></div>
        </div>
      </div>`).join('');

    // Activity feed
    document.getElementById('activity-feed').innerHTML = (stats.recentActivity||[]).slice(0,8).map(log => `
      <div class="flex items-center gap-3 px-3 py-2 rounded-xl hover:bg-gray-50 transition-colors">
        <div class="w-7 h-7 bg-brand-100 text-brand-600 rounded-lg flex items-center justify-center text-xs font-bold shrink-0">
          ${log.user ? (log.user.firstName||'?').charAt(0).toUpperCase() : '?'}
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs text-dark truncate"><span class="font-medium">${log.user ? log.user.firstName+' '+log.user.lastName : 'System'}</span> · ${(log.action||'').replace(/_/g,' ')}</p>
          <p class="text-xs text-gray-400">${new Date(log.createdAt).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'})}</p>
        </div>
        <span class="text-xs ${log.status==='success'?'text-green-600':'text-red-600'} font-medium shrink-0">${log.status}</span>
      </div>`).join('') || '<p class="text-sm text-gray-400 text-center py-4">No recent activity</p>';

  } catch (err) {
    showToast(err.message, 'error');
  }
}

loadAdminDashboard();
</script>
<%- include('../partials/footer') %>
