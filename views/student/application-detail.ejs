<%- include('../partials/head', { title: 'Application – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <%- include('../partials/sidebar-student', { user: user, activePage: 'applications' }) %>
  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="max-w-4xl">
      <a href="/student/applications" class="flex items-center gap-2 text-sm text-gray-500 hover:text-brand-600 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Back to Applications
      </a>
      <div id="app-content"><div class="card animate-pulse h-64"></div></div>
    </div>
  </main>
</div>

<!-- Upload doc modal -->
<div id="upload-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md animate-slide-up p-6">
    <h3 class="font-display text-xl font-bold text-dark mb-4">Upload Document</h3>
    <form id="upload-form" class="space-y-4">
      <div><label class="block text-sm font-medium text-dark mb-1.5">Document Type</label>
        <select name="type" required class="input-field"><option value="transcript">Transcript</option><option value="diploma">Diploma</option><option value="passport">Passport</option><option value="photo">Photo</option><option value="cv">CV</option><option value="sop">Statement of Purpose</option><option value="recommendation">Recommendation Letter</option><option value="test_score">Test Score Certificate</option><option value="financial">Financial Statement</option><option value="other">Other</option></select>
      </div>
      <div><label class="block text-sm font-medium text-dark mb-1.5">File</label><input type="file" name="document" required accept=".pdf,.jpg,.jpeg,.png" class="input-field file:mr-3 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-brand-100 file:text-brand-700" /></div>
      <div class="flex gap-3"><button type="button" onclick="document.getElementById('upload-modal').classList.add('hidden')" class="btn-secondary flex-1 justify-center">Cancel</button><button type="submit" class="btn-primary flex-1 justify-center">Upload</button></div>
    </form>
  </div>
</div>

<script>
const appId = window.location.pathname.split('/').pop();
const STATUS_COLORS = { draft:'badge-gray', submitted:'badge-blue', under_review:'badge-yellow', documents_requested:'badge-yellow', interview_scheduled:'badge-blue', offer_extended:'badge-purple', accepted:'badge-green', rejected:'badge-red', withdrawn:'badge-gray', enrolled:'badge-green' };
const STEPS = ['draft','submitted','under_review','offer_extended','accepted','enrolled'];

async function loadApplication() {
  try {
    const data = await apiCall(`/api/v1/applications/${appId}`);
    const app = data.data;
    const stepIdx = STEPS.indexOf(app.status);
    const pct = stepIdx >= 0 ? Math.round((stepIdx/(STEPS.length-1))*100) : 0;

    document.getElementById('app-content').innerHTML = `
    <div class="space-y-5">
      <!-- Header -->
      <div class="card">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-2xl overflow-hidden bg-brand-100 shrink-0">
              ${app.university?.logo?`<img src="${app.university.logo}" class="w-full h-full object-cover"/>`:`<div class="w-full h-full flex items-center justify-center font-display font-bold text-brand-600 text-2xl">${(app.university?.name||'U').charAt(0)}</div>`}
            </div>
            <div>
              <h2 class="font-display text-xl font-bold text-dark">${app.university?.name}</h2>
              <p class="text-gray-500">${app.program?.name} · <span class="text-brand-600">${app.program?.degree}</span></p>
              <p class="text-xs text-gray-400 mt-0.5">${app.intake} ${app.intakeYear} · Ref: ${app.applicationNumber}</p>
            </div>
          </div>
          <span class="${STATUS_COLORS[app.status]||'badge-gray'} text-sm px-3 py-1">${(app.status||'').replace(/_/g,' ')}</span>
        </div>
        <!-- Progress stepper -->
        <div class="mt-5 pt-5 border-t border-gray-100">
          <div class="flex items-center justify-between gap-1">
            ${STEPS.map((s,i) => `
              <div class="flex flex-col items-center gap-1.5 flex-1">
                <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold ${i<=stepIdx?'bg-brand-600 text-white':'bg-gray-200 text-gray-400'}">
                  ${i<stepIdx?'✓':i+1}
                </div>
                <span class="text-xs text-center leading-tight ${i<=stepIdx?'text-brand-600 font-medium':'text-gray-400'} hidden sm:block">${s.replace(/_/g,' ')}</span>
              </div>
              ${i<STEPS.length-1?`<div class="flex-1 h-0.5 ${i<stepIdx?'bg-brand-500':'bg-gray-200'} -mt-4"></div>`:''}`).join('')}
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 space-y-5">
          <!-- Documents -->
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-display font-bold text-dark">Documents</h3>
              ${!['rejected','withdrawn'].includes(app.status)?`<button onclick="document.getElementById('upload-modal').classList.remove('hidden')" class="btn-secondary text-xs py-1.5 px-3">+ Upload</button>`:''}
            </div>
            ${app.documents?.length?`
            <div class="space-y-2">
              ${app.documents.map(d=>`
              <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-brand-100 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  </div>
                  <div><p class="text-sm font-medium text-dark capitalize">${(d.type||'').replace(/_/g,' ')}</p><p class="text-xs text-gray-400">${d.name||''}</p></div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="badge ${d.status==='verified'?'badge-green':d.status==='rejected'?'badge-red':'badge-gray'} text-xs">${d.status||'pending'}</span>
                  <a href="${d.url}" target="_blank" class="btn-secondary text-xs py-1 px-2.5">View</a>
                </div>
              </div>`).join('')}
            </div>`:`<p class="text-sm text-gray-400">No documents uploaded yet</p>`}
          </div>

          ${app.personalStatement?`
          <div class="card">
            <h3 class="font-display font-bold text-dark mb-3">Personal Statement</h3>
            <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-wrap">${app.personalStatement}</p>
          </div>`:'' }
        </div>

        <!-- Timeline + Info -->
        <div class="space-y-4">
          <div class="card">
            <h3 class="font-display font-bold text-dark mb-4">Timeline</h3>
            <div class="space-y-3">
              ${(app.timeline||[]).map((t,i)=>`
              <div class="flex gap-3">
                <div class="relative flex flex-col items-center">
                  <div class="w-2.5 h-2.5 rounded-full ${i===0?'bg-brand-600':'bg-gray-300'} mt-0.5 shrink-0"></div>
                  ${i<(app.timeline.length-1)?'<div class="w-px flex-1 bg-gray-200 mt-1"></div>':''}
                </div>
                <div class="pb-3">
                  <p class="text-xs font-semibold text-dark capitalize">${(t.status||'').replace(/_/g,' ')}</p>
                  ${t.message?`<p class="text-xs text-gray-500 mt-0.5">${t.message}</p>`:''}
                  <p class="text-xs text-gray-400 mt-0.5">${new Date(t.timestamp).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'})}</p>
                </div>
              </div>`).join('')}
            </div>
          </div>

          ${app.offerRef?`<div class="card bg-green-50 border-green-200">
            <p class="font-bold text-green-800 text-sm mb-2">🎉 Offer Received!</p>
            <a href="/student/offers/${app.offerRef._id||app.offerRef}" class="btn-primary bg-green-600 hover:bg-green-700 w-full justify-center text-sm">View Offer →</a>
          </div>`:''}

          ${app.status==='draft'?`<button onclick="submitApplication()" class="btn-primary w-full justify-center">Submit Application →</button>`:''}
        </div>
      </div>
    </div>`;
  } catch (err) { document.getElementById('app-content').innerHTML = `<div class="card text-center py-8 text-red-500">${err.message}</div>`; }
}

async function submitApplication() {
  try {
    await apiCall(`/api/v1/applications/${appId}/submit`, { method: 'PATCH' });
    showToast('Application submitted successfully!', 'success');
    setTimeout(loadApplication, 800);
  } catch (err) { showToast(err.message, 'error'); }
}

document.getElementById('upload-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const btn = e.target.querySelector('[type=submit]');
  btn.disabled = true; btn.textContent = 'Uploading…';
  try {
    const res = await fetch(`/api/v1/applications/${appId}/documents`, { method:'POST', body:fd, credentials:'include' });
    const data = await res.json();
    if (!data.success) throw new Error(data.message);
    showToast('Document uploaded!', 'success');
    document.getElementById('upload-modal').classList.add('hidden');
    e.target.reset();
    loadApplication();
  } catch (err) { showToast(err.message,'error'); }
  finally { btn.disabled=false; btn.textContent='Upload'; }
});

loadApplication();
</script>
<%- include('../partials/footer') %>
