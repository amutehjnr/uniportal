<%- include('../partials/head', { title: 'Notifications – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <%- include('../partials/sidebar-student', { user: user, activePage: 'notifications' }) %>
  <main class="flex-1 p-6 lg:p-8 animate-fade-in">
    <div class="max-w-3xl">
      <div class="flex items-center justify-between mb-6">
        <div><h1 class="font-display text-2xl font-bold text-dark">Notifications</h1><p id="unread-count" class="text-sm text-gray-500 mt-1"></p></div>
        <button onclick="markAllRead()" class="btn-secondary text-sm">Mark all as read</button>
      </div>
      <div id="notif-list" class="space-y-2">
        <div class="animate-pulse space-y-2"><% for(let i=0;i<5;i++){%><div class="card h-16 bg-gray-50"></div><%}%></div>
      </div>
      <div id="load-more" class="text-center mt-6 hidden">
        <button onclick="loadMore()" class="btn-secondary">Load More</button>
      </div>
    </div>
  </main>
</div>
<script>
let page = 1;
const TYPE_ICONS = {
  application_update: '📋', offer_received: '🎉', payment_update: '💳',
  message_received: '💬', document_request: '📎', deadline_reminder: '⏰',
  profile_incomplete: '👤', system: '🔔',
};

async function loadNotifications(append = false) {
  try {
    const data = await apiCall(`/api/v1/notifications?page=${page}&limit=20`);
    const container = document.getElementById('notif-list');
    document.getElementById('unread-count').textContent = `${data.unread || 0} unread · ${data.pagination.total} total`;

    if (!append) container.innerHTML = '';
    if (!data.data.length && !append) {
      container.innerHTML = '<div class="card text-center py-12"><p class="text-gray-400">No notifications</p></div>'; return;
    }

    data.data.forEach(n => {
      container.insertAdjacentHTML('beforeend', `
        <div onclick="readNotification('${n._id}', '${n.link||''}')" class="card cursor-pointer hover:shadow-md transition-all ${!n.isRead ? 'border-brand-200 bg-brand-50/30' : ''} flex items-start gap-4 p-4">
          <div class="w-10 h-10 ${!n.isRead ? 'bg-brand-100' : 'bg-gray-100'} rounded-xl flex items-center justify-center text-xl shrink-0">
            ${TYPE_ICONS[n.type] || '🔔'}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <p class="font-medium text-dark text-sm ${!n.isRead ? 'font-semibold' : ''}">${n.title}</p>
              <span class="text-xs text-gray-400 shrink-0">${formatTime(n.createdAt)}</span>
            </div>
            <p class="text-xs text-gray-500 mt-0.5 line-clamp-2">${n.body}</p>
          </div>
          ${!n.isRead ? '<div class="w-2 h-2 rounded-full bg-brand-500 shrink-0 mt-1.5"></div>' : ''}
        </div>`);
    });

    const btn = document.getElementById('load-more');
    if (data.pagination.pages > page) btn.classList.remove('hidden');
    else btn.classList.add('hidden');
  } catch (err) { showToast(err.message, 'error'); }
}

async function readNotification(id, link) {
  await apiCall(`/api/v1/notifications/${id}/read`, { method: 'PATCH' }).catch(()=>{});
  if (link) window.location.href = link;
  else loadNotifications();
}

async function markAllRead() {
  await apiCall('/api/v1/notifications/read-all', { method: 'PATCH' }).catch(()=>{});
  showToast('All notifications marked as read', 'success');
  loadNotifications();
}

function loadMore() { page++; loadNotifications(true); }
function formatTime(d) { const dt=new Date(d),now=new Date(); return dt.toDateString()===now.toDateString()?dt.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}):dt.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }

loadNotifications();
</script>
<%- include('../partials/footer') %>
