<%- include('../partials/head', { title: 'Messages – UniPortal' }) %>
<%- include('../partials/navbar', { user: user }) %>
<div class="flex min-h-[calc(100vh-64px)]">
  <%- include('../partials/sidebar-student', { user: user, activePage: 'messages' }) %>
  <main class="flex-1 flex overflow-hidden" style="height:calc(100vh - 64px)">
    <!-- Conversations List -->
    <div id="convos-panel" class="w-80 shrink-0 border-r border-gray-100 bg-white flex flex-col">
      <div class="p-4 border-b border-gray-100">
        <h2 class="font-display font-bold text-dark">Messages</h2>
      </div>
      <div id="convos-list" class="flex-1 overflow-y-auto divide-y divide-gray-50">
        <div class="p-4 text-sm text-gray-400 text-center">Loading…</div>
      </div>
    </div>

    <!-- Chat Panel -->
    <div id="chat-panel" class="flex-1 flex flex-col bg-surface">
      <!-- Empty state -->
      <div id="empty-state" class="flex-1 flex items-center justify-center">
        <div class="text-center">
          <div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <p class="font-medium text-dark">Select a conversation</p>
          <p class="text-sm text-gray-400 mt-1">Choose a conversation from the left panel</p>
        </div>
      </div>

      <!-- Active chat -->
      <div id="active-chat" class="hidden flex-1 flex flex-col">
        <div id="chat-header" class="px-5 py-4 bg-white border-b border-gray-100 flex items-center gap-3">
          <div id="chat-avatar" class="w-9 h-9 rounded-xl bg-brand-100 flex items-center justify-center font-bold text-brand-600"></div>
          <div>
            <p id="chat-name" class="font-semibold text-dark text-sm"></p>
            <p id="chat-subject" class="text-xs text-gray-400"></p>
          </div>
        </div>

        <div id="messages-container" class="flex-1 overflow-y-auto p-5 space-y-4"></div>

        <!-- Typing indicator -->
        <div id="typing-indicator" class="hidden px-5 pb-2">
          <span class="text-xs text-gray-400 italic">Someone is typing…</span>
        </div>

        <!-- Input -->
        <div class="p-4 bg-white border-t border-gray-100">
          <div class="flex items-end gap-3">
            <textarea id="message-input" rows="1" placeholder="Type a message…" class="input-field resize-none flex-1" style="min-height:44px;max-height:120px" onkeydown="handleMsgKey(event)" oninput="autoResize(this);sendTyping()"></textarea>
            <button onclick="sendMessage()" class="btn-primary px-4 py-2.5 shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="https://cdn.socket.io/4.6.0/socket.io.min.js"></script>
<script>
let activeConvoId = null;
let socket = null;
let typingTimeout = null;

async function initMessages() {
  // Connect socket
  try {
    const tokenRes = await fetch('/api/v1/auth/refresh', { method:'POST', credentials:'include' });
    // Socket connects using cookie auth
    socket = io({ auth: { token: '' }, withCredentials: true });
    socket.on('message:new', (msg) => {
      if (activeConvoId && msg.conversation === activeConvoId) appendMessage(msg);
    });
    socket.on('typing:start', () => { document.getElementById('typing-indicator').classList.remove('hidden'); });
    socket.on('typing:stop', () => { document.getElementById('typing-indicator').classList.add('hidden'); });
  } catch {}

  loadConversations();
}

async function loadConversations() {
  try {
    const data = await apiCall('/api/v1/messages/conversations');
    const list = document.getElementById('convos-list');
    if (!data.data.length) {
      list.innerHTML = '<div class="p-4 text-sm text-gray-400 text-center">No conversations yet</div>'; return;
    }
    list.innerHTML = data.data.map(c => {
      const other = c.participants?.find(p => p._id !== '<%= user._id %>') || c.participants?.[0];
      const initials = other ? (other.firstName||'?').charAt(0).toUpperCase() : '?';
      return `
      <button onclick="openConversation('${c._id}', '${other?.firstName||''} ${other?.lastName||''}', '${c.subject||''}')"
        class="w-full text-left px-4 py-3.5 hover:bg-brand-50 transition-colors flex items-center gap-3 ${activeConvoId===c._id?'bg-brand-50':''}" id="convo-${c._id}">
        <div class="w-9 h-9 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center font-bold text-sm shrink-0">${initials}</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-dark truncate">${other ? other.firstName+' '+other.lastName : 'Unknown'}</p>
          <p class="text-xs text-gray-400 truncate">${c.lastMessage?.content || c.subject || 'No messages yet'}</p>
        </div>
        ${c.lastMessage?.at ? `<span class="text-xs text-gray-400 shrink-0">${formatTime(c.lastMessage.at)}</span>` : ''}
      </button>`;
    }).join('');
  } catch (err) { showToast(err.message, 'error'); }
}

async function openConversation(id, name, subject) {
  activeConvoId = id;
  document.getElementById('empty-state').classList.add('hidden');
  document.getElementById('active-chat').classList.remove('hidden');
  document.getElementById('chat-name').textContent = name;
  document.getElementById('chat-subject').textContent = subject || 'Direct Message';
  document.getElementById('chat-avatar').textContent = name.charAt(0).toUpperCase();

  // Highlight active convo
  document.querySelectorAll('[id^=convo-]').forEach(el => el.classList.remove('bg-brand-50','border-l-2','border-brand-500'));
  document.getElementById('convo-' + id)?.classList.add('bg-brand-50');

  if (socket) {
    socket.emit('join:conversation', id);
  }

  try {
    const data = await apiCall(`/api/v1/messages/conversations/${id}/messages`);
    const container = document.getElementById('messages-container');
    if (!data.data.length) {
      container.innerHTML = '<div class="text-center text-sm text-gray-400 py-8">No messages yet. Say hello!</div>';
    } else {
      container.innerHTML = data.data.map(m => renderMessage(m)).join('');
      container.scrollTop = container.scrollHeight;
    }
  } catch (err) { showToast(err.message, 'error'); }
}

function renderMessage(msg) {
  const isMine = msg.sender?._id === '<%= user._id %>' || msg.sender === '<%= user._id %>';
  return `
  <div class="flex ${isMine ? 'justify-end' : 'justify-start'} gap-2">
    ${!isMine ? `<div class="w-7 h-7 bg-brand-100 text-brand-700 rounded-lg flex items-center justify-center text-xs font-bold shrink-0 self-end">${(msg.sender?.firstName||'?').charAt(0).toUpperCase()}</div>` : ''}
    <div class="max-w-[70%]">
      <div class="px-4 py-2.5 rounded-2xl text-sm ${isMine ? 'bg-brand-600 text-white rounded-br-sm' : 'bg-white border border-gray-100 text-dark rounded-bl-sm shadow-sm'}">
        ${escHtml(msg.content)}
      </div>
      <p class="text-xs text-gray-400 mt-1 ${isMine ? 'text-right' : 'text-left'}">${formatTime(msg.createdAt)}</p>
    </div>
  </div>`;
}

function appendMessage(msg) {
  const container = document.getElementById('messages-container');
  const noMsgEl = container.querySelector('.text-center');
  if (noMsgEl) noMsgEl.remove();
  container.insertAdjacentHTML('beforeend', renderMessage(msg));
  container.scrollTop = container.scrollHeight;
}

async function sendMessage() {
  const input = document.getElementById('message-input');
  const content = input.value.trim();
  if (!content || !activeConvoId) return;
  input.value = '';
  input.style.height = 'auto';
  try {
    const data = await apiCall(`/api/v1/messages/conversations/${activeConvoId}/messages`, {
      method: 'POST', body: JSON.stringify({ content }),
    });
    appendMessage(data.data);
  } catch (err) { showToast(err.message, 'error'); }
}

function handleMsgKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function sendTyping() {
  if (socket && activeConvoId) {
    socket.emit('typing:start', { conversationId: activeConvoId });
    clearTimeout(typingTimeout);
    typingTimeout = setTimeout(() => socket.emit('typing:stop', { conversationId: activeConvoId }), 2000);
  }
}

function autoResize(el) { el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 120) + 'px'; }
function formatTime(d) { const dt = new Date(d); const now = new Date(); return dt.toDateString()===now.toDateString() ? dt.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) : dt.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

initMessages();
</script>
<%- include('../partials/footer') %>
