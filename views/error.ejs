<%- include('./partials/head', { title: title || 'Error – UniPortal' }) %>
<%- include('./partials/navbar', { user: user || null }) %>
<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="text-center animate-slide-up max-w-md">
    <p class="font-display text-9xl font-bold text-brand-100 mb-0 leading-none"><%= statusCode || 500 %></p>
    <h1 class="font-display text-2xl font-bold text-dark mt-2 mb-3"><%= statusCode === 404 ? 'Page Not Found' : 'Something Went Wrong' %></h1>
    <p class="text-gray-500 mb-8"><%= message || 'An unexpected error occurred.' %></p>
    <div class="flex gap-3 justify-center">
      <a href="javascript:history.back()" class="btn-secondary">← Go Back</a>
      <a href="/" class="btn-primary">Go Home</a>
    </div>
  </div>
</div>
<%- include('./partials/footer') %>
